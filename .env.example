# Attio
ATTIO_API_KEY=

# Google Gemini (Google AI Studio)
GOOGLE_API_KEY=
# Optional model overrides
GEMINI_VOICE_MODEL=gemini-3.5-flash
GEMINI_PLAN_MODEL=gemini-3.5-flash
GEMINI_BROWSER_MODEL=gemini-3.5-flash

# SLNG (voice STT/TTS)
SLNG_API_KEY=
SLNG_STT_MODEL=deepgram/nova:3
SLNG_TTS_MODEL=deepgram/aura:2

# LiveKit Cloud
LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
# Sandbox can only deliver to the account owner address until a domain is verified
DEMO_CUSTOMER_EMAIL=

# Mock Acme product admin (provisioning target)
ACME_ADMIN_USER=admin@acme.test
ACME_ADMIN_PASS=acme-admin-pass

# Public URL of this service (Render URL in prod, tunnel URL locally)
PUBLIC_BASE_URL=http://localhost:8000

# Provisioning: browser_use (agentic, default) | playwright (deterministic)
PROVISION_MODE=browser_use
